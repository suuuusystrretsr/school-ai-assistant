APP_NAME=SCHOOL AI ASSISTANT
SITE_URL=https://schoolaiassistant.local
API_URL=http://localhost:8000/api/v1

# Backend (SQLite-first for easiest free deployment)
DATABASE_URL=sqlite:///./school_ai_assistant.db
JWT_SECRET=replace-with-a-secure-random-string
AI_PROVIDER=mock
AI_MODEL=mock-edu-v1
CORS_ORIGINS=*

# Frontend
NEXT_PUBLIC_APP_NAME=SCHOOL AI ASSISTANT
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:8000

# Hugging Face (optional smarter AI)
HF_API_KEY=
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
HF_TIMEOUT_SECONDS=35
HF_MAX_NEW_TOKENS=500

